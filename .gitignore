# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# (.env.example is intentionally tracked as a template)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────────
# Local-only working files (NEVER push)
# ─────────────────────────────────────────────────────────────────

# Generation progress + logs
/scripts/progress.json
/logs/

# Panchang + generative image cache
/.cache/

# Claude Code internal
/.claude/

# Local screenshots from QA passes
/screenshots/

# Reference template — local only design references
/reference/

# ─────────────────────────────────────────────────────────────────
# Public assets — selective: brand assets, icons, real post images
# all GO to remote so the production build can render them.
# Reference HTML, design templates, and Brand Stones reference
# images stay local-only.
# ─────────────────────────────────────────────────────────────────
/public/Brand Stones/
/public/Presence links.txt
/public/reference/
/public/vastucart_blog_enterprise_v2.html
/public/vastucart_blog_enterprise_v2.html:Zone.Identifier
/public/category_variation_system.html
/public/category_variation_system.html:Zone.Identifier
/public/astroengine-api-reference.md
/public/zodiac icons/
# legacy duplicate of nakshatras/, the canonical dir without the s
/public/nakshatra/

# WSL Zone.Identifier sidecar files (Windows interop artifacts)
*:Zone.Identifier
